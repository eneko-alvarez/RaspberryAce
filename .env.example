# Copy this file to .env and fill your local values.
# Docker Compose reads .env automatically from this directory.

TMDB_ACCESS_TOKEN=
TMDB_API_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
TMDB_LANGUAGE=es-ES
TMDB_REGION=ES

# Future legal VOD provider integration.
VOD_PROVIDER_BASE_URL=https://vidsrc.mov
VOD_PROVIDER_TOKEN=

# Used by docker-compose.dev.yml when running only webplayer/VOD.
PROXY_HOST=192.168.1.125
PROXY_PORT=8888
